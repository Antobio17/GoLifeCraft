<?xml version="1.0" encoding="utf-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity repository-class="Authorization\User\User\Infrastructure\Domain\Model\Doctrine\DoctrineUserRepository" name="Authorization\User\User\Domain\Model\User" table="user">
    <id name="id" type="string" column="id" primary="true" length="36"/>
    <field name="version" type="integer" version="true"/>
    <field name="name" type="string" column="name" length="255" nullable="true"/>
    <field name="lastname" type="string" column="lastname" length="255" nullable="true"/>
    <field name="roles" type="json" column="roles"/>
    <field name="email" type="string" column="email" length="255"/>
    <field name="username" type="string" column="username" length="255"/>
    <field name="password" type="string" column="password" length="255"/>
    <field name="tenantId" type="string" column="tenant_id" length="14"/>
    <field name="role" type="string" column="role" length="30"/>
    <field name="isActive" type="boolean" column="is_active"/>
    <field name="createdAt" type="datetime" column="created_at"/>
    <field name="updatedAt" type="datetime" column="updated_at"/>
    <field name="createdByUserId" type="string" column="created_by_user_id" length="36"/>
    <field name="updatedByUserId" type="string" column="updated_by_user_id" length="36"/>
    <unique-constraints>
      <unique-constraint name="uniq_user_username" columns="username"/>
      <unique-constraint name="uniq_user_email" columns="email"/>
    </unique-constraints>
    <indexes>
      <index name="idx_user_tenant_id" columns="tenant_id"/>
      <index name="idx_user_tenant_role" columns="tenant_id,role"/>
      <index name="idx_user_tenant_active" columns="tenant_id,is_active"/>
    </indexes>
  </entity>
</doctrine-mapping>