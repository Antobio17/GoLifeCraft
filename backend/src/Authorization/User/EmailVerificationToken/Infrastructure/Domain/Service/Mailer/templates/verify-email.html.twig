{% trans_default_domain 'email_verification_token' %}
{% set lang = languageCode|default('es') %}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="color-scheme" content="light only">
<meta name="supported-color-schemes" content="light">
<title>{{ 'subject'|trans({}, 'email_verification_token', lang) }}</title>
<style>
  :root { color-scheme: light only; supported-color-schemes: light; }
  html, body { margin:0; padding:0; background:#f6f2e9; font-family:'Hanken Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; -webkit-font-smoothing:antialiased; }
  table { border-collapse:collapse; }
  img { border:0; display:block; }
  a { color:#274b37; }
  .brand-logo { width:180px; max-width:100%; height:auto; }
  .shell { padding:48px 16px 56px; }
  .card { width:600px; max-width:600px; background:#ffffff; border:1px solid #eae4d6; border-radius:24px; overflow:hidden; box-shadow:0 22px 50px -34px rgba(27,25,21,0.20), 0 6px 14px rgba(27,25,21,0.05); }
  .brand-row { padding:30px 40px 24px; }
  .hero { background:#eef4ea; border-bottom:1px solid #dce9d6; }
  .hero-pad { padding:52px 40px 44px; }
  .content-pad { padding:40px 40px 0; }
  .button-cell { padding:28px 40px 8px; }
  .button { min-width:260px; }
  .footer-pad { padding:24px 8px 15px; }
  @media only screen and (max-width:620px) {
    .container { width:100% !important; }
    .shell { padding:36px 16px 44px !important; }
    .pad-x { padding-left:28px !important; padding-right:28px !important; }
    .hero-pad { padding:44px 28px 40px !important; }
    .h1 { font-size:23px !important; line-height:1.32 !important; letter-spacing:-0.018em !important; }
    .brand-row { padding:22px 28px 18px !important; }
    .brand-logo { width:150px !important; }
    .brand-logo-cell, .brand-tag-cell { display:block !important; width:100% !important; text-align:left !important; }
    .brand-tag-cell { padding-top:12px !important; }
    .content-pad { padding:36px 28px 0 !important; }
    .button-cell { padding:30px 28px 8px !important; }
    .button { min-width:0 !important; width:100% !important; }
    .footer-pad { padding-left:0 !important; padding-right:0 !important; }
  }
</style>
</head>
<body style="margin:0; padding:0; background:#f6f2e9; font-family:'Hanken Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; color:#1b1a15;">

  <div style="display:none; max-height:0; overflow:hidden; opacity:0; color:transparent; visibility:hidden; mso-hide:all;">
    {{ 'preheader'|trans({ '%hours%': ttlHours }, 'email_verification_token', lang) }}
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f6f2e9;">
    <tr>
      <td align="center" class="shell">

        <table role="presentation" class="container" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px; max-width:600px;">

          <tr>
            <td class="brand-row" style="font-size:0; line-height:0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="left" valign="middle" class="brand-logo-cell" style="line-height:0;">
                    {% set logoSource = logoUrl is defined and logoUrl ? logoUrl : email.image(logoPath) %}
                    <img src="{{ logoSource }}" alt="GoLifeCraft" width="180" height="57" class="brand-logo" style="display:block; border:0; outline:none; text-decoration:none;">
                  </td>
                  <td align="right" valign="middle" class="brand-tag-cell" style="font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#9a958a; white-space:nowrap;">
                    {{ 'brand.tag'|trans({}, 'email_verification_token', lang) }}
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td class="card" style="background:#ffffff; border:1px solid #eae4d6; border-radius:24px; overflow:hidden;">

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="hero" style="background:#eef4ea; border-bottom:1px solid #dce9d6;">
                <tr>
                  <td class="hero-pad" style="font-family:'Hanken Grotesk', Helvetica, Arial, sans-serif;">

                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="background:#ffffff; border:1px solid #cfe3c4; border-radius:100px;">
                      <tr>
                        <td style="padding:6px 12px; font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#274b37; font-weight:500;">
                          <span style="color:#b4e839;">●</span> {{ 'hero.eyebrow'|trans({}, 'email_verification_token', lang) }}
                        </td>
                      </tr>
                    </table>

                    <p style="margin:22px 0 0; font-size:26px; line-height:1.15; font-weight:700; letter-spacing:-0.025em; color:#1b1a15;" class="h1">
                      {{ 'hero.title'|trans({}, 'email_verification_token', lang) }}
                    </p>
                    <p style="margin:10px 0 0; font-size:14px; line-height:1.55; color:#6f6a5c;">
                      {{ 'hero.subtitle'|trans({}, 'email_verification_token', lang) }}
                    </p>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="content-pad pad-x">
                    <p style="margin:0; font-size:17px; font-weight:600; color:#1b1a15; letter-spacing:-0.01em;">
                      {{ 'greeting'|trans({ '%name%': name }, 'email_verification_token', lang) }}
                    </p>
                    <p style="margin:12px 0 0; font-size:15px; line-height:1.6; color:#4a463d;">
                      {{ 'intro'|trans({}, 'email_verification_token', lang)|raw }}
                    </p>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" class="button-cell pad-x">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" class="button" style="background:#274b37; border-radius:14px;">
                          <a href="{{ verifyUrl }}" target="_blank"
                             style="display:block; padding:16px 28px; font-family:'Hanken Grotesk', Helvetica, Arial, sans-serif; font-size:15px; font-weight:700; color:#ffffff; text-decoration:none; letter-spacing:-0.005em; text-align:center;">
                            {{ 'cta'|trans({}, 'email_verification_token', lang) }}
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:18px 40px 0;" align="center">
                    <div style="font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; letter-spacing:0.08em; color:#9a958a;">
                      {{ 'expires'|trans({ '%hours%': ttlHours }, 'email_verification_token', lang) }}
                    </div>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:28px 40px 0;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f6f2e9; border:1px solid #eae4d6; border-radius:12px;">
                      <tr>
                        <td style="padding:14px 16px;">
                          <div style="font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:#9a958a; margin-bottom:6px;">
                            {{ 'fallback.label'|trans({}, 'email_verification_token', lang) }}
                          </div>
                          <div style="font-family:'JetBrains Mono','Courier New',monospace; font-size:12px; line-height:1.5; color:#274b37; word-break:break-all;">
                            <a href="{{ verifyUrl }}" target="_blank" style="color:#274b37; text-decoration:none;">{{ verifyUrl }}</a>
                          </div>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:24px 40px 48px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top:1px solid #eae4d6;">
                      <tr>
                        <td style="padding-top:18px;">
                          <p style="margin:0; font-size:13px; line-height:1.55; color:#6f6a5c;">
                            <strong style="color:#1b1a15; font-weight:600;">{{ 'warning.title'|trans({}, 'email_verification_token', lang) }}</strong>
                            {{ 'warning.body'|trans({}, 'email_verification_token', lang) }}
                            <a href="mailto:{{ 'warning.support_email'|trans({}, 'email_verification_token', lang) }}" style="color:#274b37; text-decoration:none; font-weight:500;">{{ 'warning.support_email'|trans({}, 'email_verification_token', lang) }}</a>.
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <tr>
            <td style="padding:24px 8px 15px; font-family:'Hanken Grotesk', Helvetica, Arial, sans-serif; background:#f6f2e9;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:#9a958a;">
                    {{ 'footer.compliance'|trans({}, 'email_verification_token', lang) }}
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-top:14px; font-family:'Hanken Grotesk', Helvetica, Arial, sans-serif; font-size:12px; line-height:1.6; color:#9a958a;">
                    {{ 'footer.copyright'|trans({}, 'email_verification_token', lang) }}<br>
                    {{ 'footer.confidential'|trans({}, 'email_verification_token', lang) }}
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-top:10px; font-family:'Hanken Grotesk', Helvetica, Arial, sans-serif; font-size:12px; color:#9a958a;">
                    <a href="#" style="color:#9a958a; text-decoration:none;">{{ 'footer.help'|trans({}, 'email_verification_token', lang) }}</a>
                    &nbsp;·&nbsp;
                    <a href="#" style="color:#9a958a; text-decoration:none;">{{ 'footer.privacy'|trans({}, 'email_verification_token', lang) }}</a>
                    &nbsp;·&nbsp;
                    <a href="#" style="color:#9a958a; text-decoration:none;">{{ 'footer.site'|trans({}, 'email_verification_token', lang) }}</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
