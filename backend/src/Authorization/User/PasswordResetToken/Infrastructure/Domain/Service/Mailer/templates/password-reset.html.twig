{% trans_default_domain 'password_reset_token' %}
{% set lang = languageCode|default('es') %}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ 'subject'|trans({}, 'password_reset_token', lang) }}</title>
<style>
  body { margin:0; padding:0; background:#eef2f7; font-family:'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; -webkit-font-smoothing:antialiased; }
  table { border-collapse:collapse; }
  img { border:0; display:block; }
  a { color:#2f9e44; }
  .mono { font-family:'JetBrains Mono', 'Courier New', monospace; letter-spacing:0.08em; }
  @media only screen and (max-width:620px) {
    .container { width:100% !important; }
    .pad-x { padding-left:24px !important; padding-right:24px !important; }
    .hero-pad { padding:48px 24px 40px !important; }
    .h1 { font-size:24px !important; line-height:1.25 !important; }
  }
</style>
</head>
<body style="margin:0; padding:0; background:#eef2f7; font-family:'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; color:#0f1923;">

  <div style="display:none; max-height:0; overflow:hidden; opacity:0; color:transparent; visibility:hidden; mso-hide:all;">
    {{ 'preheader'|trans({ '%minutes%': ttlMinutes }, 'password_reset_token', lang) }}
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#eef2f7; padding:64px 16px 72px;">
    <tr>
      <td align="center">

        <table role="presentation" class="container" width="560" cellpadding="0" cellspacing="0" border="0" style="width:560px; max-width:560px;">

          <tr>
            <td style="padding:10px 4px 18px; font-size:0; line-height:0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="left" valign="middle" style="font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:22px; font-weight:700; letter-spacing:-0.02em; color:#2f9e44;">
                    GoLifeCraft
                  </td>
                  <td align="right" valign="middle" style="font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#94a3b8;">
                    {{ 'brand.tag'|trans({}, 'password_reset_token', lang) }}
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="background:#ffffff; border-radius:18px; box-shadow:0 1px 0 rgba(255,255,255,0.6) inset, 0 24px 48px -20px rgba(13,21,32,0.18), 0 4px 12px -4px rgba(13,21,32,0.08); overflow:hidden;">

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#eefaf0; border-bottom:1px solid #e2e8f0;">
                <tr>
                  <td class="hero-pad" style="padding:52px 40px 44px; font-family:'DM Sans', Helvetica, Arial, sans-serif;">

                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="background:#ffffff; border:1px solid #d3f0da; border-radius:100px;">
                      <tr>
                        <td style="padding:6px 12px; font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:#2f9e44; font-weight:500;">
                          ● {{ 'hero.eyebrow'|trans({}, 'password_reset_token', lang) }}
                        </td>
                      </tr>
                    </table>

                    <p style="margin:22px 0 0; font-size:26px; line-height:1.15; font-weight:700; letter-spacing:-0.025em; color:#0f1923; font-family:'DM Sans', Helvetica, Arial, sans-serif;" class="h1">
                      {{ 'hero.title'|trans({}, 'password_reset_token', lang) }}
                    </p>
                    <p style="margin:10px 0 0; font-size:14px; line-height:1.55; color:#5a6a7e; font-family:'DM Sans', Helvetica, Arial, sans-serif;">
                      {{ 'hero.subtitle'|trans({}, 'password_reset_token', lang) }}
                    </p>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:44px 40px 8px; font-family:'DM Sans', Helvetica, Arial, sans-serif;">

                    <p style="margin:0; font-size:17px; font-weight:600; color:#0f1923; letter-spacing:-0.01em;">
                      {{ 'greeting'|trans({ '%name%': name }, 'password_reset_token', lang) }}
                    </p>
                    <p style="margin:12px 0 0; font-size:15px; line-height:1.6; color:#5a6a7e;">
                      {{ 'intro'|trans({}, 'password_reset_token', lang)|raw }}
                    </p>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" class="pad-x" style="padding:28px 40px 8px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="background:#2f9e44; border-radius:10px; box-shadow:0 6px 14px rgba(47,158,68,0.28);">
                          <a href="{{ resetUrl }}" target="_blank"
                             style="display:inline-block; padding:14px 28px; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; letter-spacing:-0.005em;">
                            {{ 'cta'|trans({}, 'password_reset_token', lang) }}
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:18px 40px 0;" align="center">
                    <div style="font-family:'JetBrains Mono','Courier New',monospace; font-size:11px; letter-spacing:0.08em; color:#94a3b8;">
                      {{ 'expires'|trans({ '%minutes%': ttlMinutes }, 'password_reset_token', lang) }}
                    </div>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:28px 40px 0;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f4f7fb; border:1px solid #e2e8f0; border-radius:12px;">
                      <tr>
                        <td style="padding:14px 16px;">
                          <div style="font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:#94a3b8; margin-bottom:6px;">
                            {{ 'fallback.label'|trans({}, 'password_reset_token', lang) }}
                          </div>
                          <div style="font-family:'JetBrains Mono','Courier New',monospace; font-size:12px; line-height:1.5; color:#2f9e44; word-break:break-all;">
                            <a href="{{ resetUrl }}" target="_blank" style="color:#2f9e44; text-decoration:none;">{{ resetUrl }}</a>
                          </div>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:24px 40px 4px;">
                    <div style="font-family:'JetBrains Mono','Courier New',monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:#94a3b8;">{{ 'meta.requested'|trans({}, 'password_reset_token', lang) }}</div>
                    <div style="font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:13.5px; color:#0f1923; margin-top:3px; font-weight:500;">{{ requestedAtFormatted }}</div>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="pad-x" style="padding:24px 40px 48px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top:1px solid #e2e8f0;">
                      <tr>
                        <td style="padding-top:18px;">
                          <p style="margin:0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.55; color:#5a6a7e;">
                            <strong style="color:#0f1923; font-weight:600;">{{ 'warning.title'|trans({}, 'password_reset_token', lang) }}</strong>
                            {{ 'warning.body'|trans({}, 'password_reset_token', lang) }}
                            <a href="mailto:{{ 'warning.support_email'|trans({}, 'password_reset_token', lang) }}" style="color:#2f9e44; text-decoration:none; font-weight:500;">{{ 'warning.support_email'|trans({}, 'password_reset_token', lang) }}</a>.
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <tr>
            <td style="padding:24px 8px 15px; font-family:'DM Sans', Helvetica, Arial, sans-serif;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="font-family:'JetBrains Mono','Courier New',monospace; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:#94a3b8;">
                    {{ 'footer.compliance'|trans({}, 'password_reset_token', lang) }}
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-top:14px; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:12px; line-height:1.6; color:#94a3b8;">
                    {{ 'footer.copyright'|trans({}, 'password_reset_token', lang) }}<br>
                    {{ 'footer.confidential'|trans({}, 'password_reset_token', lang) }}
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-top:10px; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:12px; color:#94a3b8;">
                    <a href="#" style="color:#94a3b8; text-decoration:none;">{{ 'footer.help'|trans({}, 'password_reset_token', lang) }}</a>
                    &nbsp;·&nbsp;
                    <a href="#" style="color:#94a3b8; text-decoration:none;">{{ 'footer.privacy'|trans({}, 'password_reset_token', lang) }}</a>
                    &nbsp;·&nbsp;
                    <a href="#" style="color:#94a3b8; text-decoration:none;">{{ 'footer.site'|trans({}, 'password_reset_token', lang) }}</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
