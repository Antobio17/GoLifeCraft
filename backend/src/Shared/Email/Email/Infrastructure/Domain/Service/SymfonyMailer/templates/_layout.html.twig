<!DOCTYPE html>
<html lang="{{ languageCode|default('es') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ subject|default('GoLifeCraft') }}</title>
</head>
<body style="margin:0;padding:0;background:#f4f6f8;font-family:Arial,sans-serif;color:#0f172a;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f6f8;padding:32px 0;">
        <tr>
            <td align="center">
                <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(15,23,42,0.08);">
                    <tr>
                        <td style="background:#2f9e44;padding:24px 32px;color:#ffffff;font-size:20px;font-weight:600;">
                            GoLifeCraft
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:32px;font-size:15px;line-height:1.55;">
                            {% block content %}{% endblock %}
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 32px;background:#f1f5f9;color:#64748b;font-size:12px;line-height:1.5;">
                            {{ 'footer.legal'|trans({}, 'email', languageCode|default('es')) }}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
